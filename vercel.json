{
  "buildCommand": "npm run build",
  "outputDirectory": "dist/nviq-angular/browser",
  "framework": "angular",
  "env": {
    "NODE_OPTIONS": "--max-old-space-size=6144"
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://backend-mu-ten-23.vercel.app/api/:path*" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
