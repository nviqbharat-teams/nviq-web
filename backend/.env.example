# ─── Server ───────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── MongoDB ──────────────────────────────────────────────
MONGO_URI=mongodb://127.0.0.1:27017/nviq_bharat
# Production example:
# MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/nviq_bharat

# ─── JWT ──────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_in_production_min_32_chars
JWT_EXPIRES_IN=7d

# ─── CORS ─────────────────────────────────────────────────
CLIENT_URL=http://localhost:4200

# ─── File Upload ──────────────────────────────────────────
MAX_FILE_SIZE_MB=5
